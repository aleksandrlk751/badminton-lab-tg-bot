# Скопируйте в .env и заполните значения

# PostgreSQL
DB_HOST=localhost
DB_PORT=5433
DB_NAME=badminton_lab
DB_USER=badminton
DB_PASSWORD=badminton

# Telegram (получить у @BotFather)
BOT_TOKEN=
TELEGRAM_BOT_ENABLED=false

# Парсер (worker)
PARSER_BASE_URL=https://badminton4u.ru/
PARSER_THREADS=8
PARSER_MAX_RPS=10
PARSER_CONNECT_TIMEOUT_MS=15000
PARSER_RETRY_MAX=3
PARSER_RETRY_BACKOFF_MS=1000
PARSER_USER_AGENT=BadmintonLabBot/0.1 (+contact@example.com)

# Слепок региона (worker)
SNAPSHOT_REGION=r77
SNAPSHOT_YEARS_BACK=3
# Дисциплины через запятую: D,MD,WD,XD
SNAPSHOT_DISCIPLINES=D,MD,WD,XD
# Ежедневный запуск по расписанию (cron в зоне Europe/Moscow)
SNAPSHOT_SCHEDULED_ENABLED=false
SNAPSHOT_CRON=0 0 4 * * *
# Разовый запуск слепка при старте worker (dev-триггер, синхронно)
SNAPSHOT_RUN_ON_STARTUP=false
# 0 = без лимита (полный слепок); >0 — «дымовой» режим на N турниров
SNAPSHOT_MAX_TOURNAMENTS=0
