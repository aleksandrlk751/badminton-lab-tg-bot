# Скопируйте в .env и заполните значения

# PostgreSQL
DB_HOST=localhost
DB_PORT=5433
DB_NAME=badminton_lab
DB_USER=badminton
DB_PASSWORD=badminton

# Telegram (получить у @BotFather)
BOT_TOKEN=
TELEGRAM_BOT_ENABLED=false

# Парсер (worker)
PARSER_THREADS=8
PARSER_MAX_RPS=10
PARSER_USER_AGENT=BadmintonLabBot/0.1 (+contact@example.com)
